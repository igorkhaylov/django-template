// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
  "name": "Django Template 8050",
  // "dockerComposeFile": "../docker-compose.yml",
  "dockerComposeFile": [
    "../docker-compose.dev.yml",
  ],
  "service": "backend",
  "workspaceFolder": "/app",
  "mounts": [
    "type=bind,source=${localEnv:HOME}/.claude,target=/root/.claude",
    "type=bind,source=${localEnv:HOME}/.claude.json,target=/root/.claude.json",
    "type=bind,source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,readonly"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "batisteo.vscode-django",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-russian",
        "albert.TabOut",
        "Gruntfuggly.todo-tree",
        "anthropic.claude-code"
      ],
      "settings": {
        // "python.defaultInterpreterPath": "/usr/local/bin/python"
        // "editor.defaultFormatter": "ms-python.black-formatter",
        // "editor.formatOnSave": true,
        // "editor.formatOnPaste": false
      }
    }
  },
  "forwardPorts": [
    // 8050
  ]
}