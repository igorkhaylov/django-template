# dev, test, stage, prod  (validated in settings; anything else raises on startup)
ENVIRONMENT=dev

# ------ APP ------
# Docker Compose project name (prefix for containers/volumes/networks). The dev and
# test stacks append -dev / -test automatically. Use a custom NOT COMPOSE_PROJECT_NAME
# so those per-stack suffixes are preserved.
PROJECT_NAME=django-template
APP_PORT=8050

# Backend image to PULL in prod (docker-compose.prod.yml / `make prod deploy`). CI builds
# and pushes this; the server only pulls. Pin a reproducible build with the sha- tag, e.g.
#   BACKEND_IMAGE=ghcr.io/igorkhaylov/django-template:sha-<full-sha>
# A moving :latest also works but drifts on the next push. (GitLab registry:
#   BACKEND_IMAGE=registry.gitlab.com/<group>/<project>:sha-<full-sha>)
BACKEND_IMAGE=ghcr.io/igorkhaylov/django-template:latest

# ------ DJANGO ------
DJANGO_APP_NAME=DjangoTemplate
# REQUIRED in stage/prod (>= 50 chars). Generate with: openssl rand -hex 64
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_ALLOWED_HOSTS=localhost,backend,
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:${APP_PORT},
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:${APP_PORT},
# Logging level for the container logs (DEBUG/INFO/WARNING/ERROR).
DJANGO_LOG_LEVEL=INFO

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME

# ------ GUNICORN ------
GUNICORN_WORKERS=4
# Worker request timeout in seconds (sync workers; default upstream is 30).
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30


# ------ POSTGRES ------
POSTGRES_DB=django_template
POSTGRES_USER=django_template_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=db
POSTGRES_PORT=5432


# ------ MINIO (shared LOCAL object storage, provisioned by `make minio`) ------
# Object storage is NOT part of docker-compose. Locally it is a single SHARED MinIO
# container on the host, reused by every project (no per-project MinIO). `make minio`
# (./scripts/ensure_minio.sh) starts it if needed and creates this project's bucket.
#
# Root credentials of that shared MinIO. Keep them as minioadmin/minioadmin to use the
# local shared MinIO. Set them to ANYTHING ELSE to signal "external/managed storage" —
# then `make minio` does nothing and you provision the bucket on your provider instead.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Host ports the shared MinIO is published on (API / console).
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# This project's bucket + restricted app user (created by `make minio`).
MINIO_BUCKET_NAME=django-template-bucket
MINIO_APP_USER=django-template-app
MINIO_APP_PASSWORD=CHANGE_ME


# ------ DJANGO MINIO (S3 storage backend Django reads) ------
# Endpoint the backend container uses to reach storage. For the shared LOCAL MinIO use
# host.docker.internal (the container talks to the host-published MinIO). For
# external/managed MinIO or S3, set this to that endpoint.
DJANGO_MINIO_ENDPOINT=http://host.docker.internal:${MINIO_PORT}
# Public base URL used when building media/static links.
DJANGO_MINIO_CUSTOM_URL=http://localhost:${MINIO_PORT}
DJANGO_MINIO_BUCKET_NAME=${MINIO_BUCKET_NAME}
DJANGO_MINIO_ACCESS_KEY=${MINIO_APP_USER}
DJANGO_MINIO_SECRET_KEY=${MINIO_APP_PASSWORD}


# ------ DB BACKUP (optional, tiredofit/db-backup — prod only) ------
# Automated DATABASE backups. DISABLED by default. Enable by activating the compose
# profile (uncomment the next line); `make prod deploy` then starts the db-backup
# service. Media is NOT covered here — see docs/backup.md.
# COMPOSE_PROFILES=backup
#
# Schedule + retention in MINUTES (defaults: every 24h, keep 7 days) + compression.
# DB_BACKUP_INTERVAL=1440
# DB_BACKUP_CLEANUP_TIME=10080
# DB_BACKUP_COMPRESSION=ZSTD
#
# Target: FILESYSTEM (default) or S3.
# DB_BACKUP_LOCATION=FILESYSTEM
# DB_BACKUP_FS_PATH=./db-backups            # host path where FILESYSTEM dumps land
#
# For S3 (set DB_BACKUP_LOCATION=S3) — a DEDICATED bucket/prefix, separate from the
# app's DJANGO_MINIO_* media storage:
# DB_BACKUP_S3_BUCKET=my-db-backups
# DB_BACKUP_S3_PATH=db-backups
# DB_BACKUP_S3_REGION=us-east-1
# DB_BACKUP_S3_KEY_ID=CHANGE_ME
# DB_BACKUP_S3_KEY_SECRET=CHANGE_ME
# DB_BACKUP_S3_HOST=https://s3.example.com  # S3-compatible endpoint; blank = AWS S3
#
# Override the pinned image if needed:
# DB_BACKUP_IMAGE=ghcr.io/tiredofit/docker-db-backup:4.1.100
